# Resend — get from https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Cloudflare Turnstile — get from https://dash.cloudflare.com/?to=/:account/turnstile
TURNSTILE_SITE_KEY=0xAAAAAAAAAAAAAAAAAAAAAA
TURNSTILE_SECRET_KEY=0xAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA

# Where signup notifications go
JACK_EMAIL=jack@flexforce.ai

# Cal.com event link for onboarding — set this up at https://cal.com
# Example: https://cal.com/jack-flexforce/pilot-onboarding
CAL_LINK=https://cal.com/jack-flexforce/pilot-onboarding

# Email sender addresses (must be verified domains in Resend)
# If flexforce.ai is not yet verified in Resend, leave these blank to fall
# back to Resend's default onboarding@resend.dev (for testing only).
MAIL_FROM_JACK=Jack at FlexForce <jack@flexforce.ai>
MAIL_FROM_SIGNUPS=FlexForce Signups <signups@flexforce.ai>
